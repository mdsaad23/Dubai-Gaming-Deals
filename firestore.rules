rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'justsaad95@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.brand is string && data.brand.size() > 0 && data.brand.size() <= 50 &&
             data.type in ['laptop', 'cpu', 'gpu'] &&
             (data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 1000));
    }

    function isValidDeal(data) {
      return data.productId is string && data.productId.size() <= 128 &&
             data.price is number && data.price > 0 &&
             data.originalPrice is number && data.originalPrice >= data.price &&
             data.store is string && data.store.size() > 0 && data.store.size() <= 100 &&
             data.url is string && data.url.size() <= 1000 &&
             data.country == 'UAE' &&
             data.updatedAt == request.time;
    }

    function isValidSubscription(data) {
      return ((data.email == null || (data.email is string && data.email.size() <= 256)) &&
              (data.whatsapp == null || (data.whatsapp is string && data.whatsapp.size() <= 50))) &&
             (data.email != null || data.whatsapp != null);
    }

    // --- Collection Routes ---

    match /products/{productId} {
      allow get: if isValidId(productId);
      allow list: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) && 
                    incoming().keys().hasAll(['name', 'brand', 'type']) &&
                    incoming().keys().size() <= 10;
      allow update: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasAny(['name', 'brand', 'type', 'specs', 'imageUrl', 'updatedAt']);
      allow delete: if isAdmin() && isValidId(productId);
    }

    match /deals/{dealId} {
      allow get: if isValidId(dealId);
      allow list: if true;
      allow create: if isAdmin() && isValidId(dealId) && isValidDeal(incoming()) &&
                    incoming().keys().hasAll(['productId', 'price', 'store', 'url', 'country', 'updatedAt']) &&
                    incoming().keys().size() <= 15;
      allow update: if isAdmin() && isValidId(dealId) && isValidDeal(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasAny(['price', 'originalPrice', 'discountPercentage', 'store', 'url', 'updatedAt', 'productName', 'productType', 'imageUrl', 'specs']);
      allow delete: if isAdmin() && isValidId(dealId);
    }

    match /subscriptions/{subId} {
      allow create: if isValidId(subId) && isValidSubscription(incoming()) &&
                    incoming().keys().hasAny(['email', 'whatsapp', 'categories', 'createdAt']) &&
                    incoming().createdAt == request.time &&
                    incoming().keys().size() <= 5;
      
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; 
    }
  }
}
