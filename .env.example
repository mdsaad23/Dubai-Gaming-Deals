# GulfDeals — Environment Variables
# Copy this file to project/backend/.env for local development
# NEVER commit .env with real credentials

# ─── Supabase (required) ──────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key   # service_role key (not anon)

# ─── Residential Proxy (strongly recommended for production) ──────────────────
# Amazon.ae and Noon block datacenter IPs. Use BrightData or Oxylabs residential.
# Without a proxy, scrapers will hit CAPTCHAs quickly.
# Leave blank for local development (direct connection — expect blocks)
PROXY_HOST=brd.superproxy.io
PROXY_PORT=22225
PROXY_USER=your-proxy-username
PROXY_PASS=your-proxy-password

# ─── Email alerts (Resend) ───────────────────────────────────────────────────
# Sign up at: https://resend.com (3,000 emails/month free tier)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM=GulfDeals <alerts@yourdomain.com>

# ─── WhatsApp alerts (Twilio) ────────────────────────────────────────────────
# Sign up at: https://twilio.com
# Sandbox: Use +14155238886 (no approval needed)
# Production: Requires WhatsApp Business API approval
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Frontend site URL (for links in alert emails) ───────────────────────────
SITE_URL=https://gulfdeals.ae

# ─── Amazon Associates Affiliate Tag ─────────────────────────────────────────
# Apply at: https://affiliate-program.amazon.com/
# Replace in amazon_ae.py → AFFILIATE_TAG
AMAZON_AFFILIATE_TAG=gulfdeals-21
